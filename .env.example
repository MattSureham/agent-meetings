# Agent Meetings — API Keys
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# DeepSeek (required for moderator/summarizer if using DeepSeek models)
DEEPSEEK_API_KEY=sk-...

# MiniMax
MINIMAX_API_KEY=

# Qwen / Alibaba
QWEN_API_KEY=

# Kimi / Moonshot
MOONSHOT_API_KEY=

# Kimi Code
KIMI_API_KEY=

# Local LLM overrides (optional — defaults are set in config)
# VLLM_MODEL=meta-llama/Llama-4-Scout-17B-16E-Instruct
# VLLM_ENDPOINT=http://127.0.0.1:8000/v1
# LMSTUDIO_MODEL=local-model
# LMSTUDIO_ENDPOINT=http://127.0.0.1:1234/v1
