  "author": "Matt Sureham",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "playwright": "^1.59.1",
    "ws": "^8.20.0",
    "yaml": "^2.8.3"
  }
}
