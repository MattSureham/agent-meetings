{
  "name": "agent-meetings",
  "version": "1.0.0",
  "description": "A framework for enabling technical meetings and communication between AI agents and LLMs",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "agent-meetings": "./dist/cli/index.js",
    "am": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
